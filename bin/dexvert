#!/usr/bin/env node
"use strict";
const XU = require("@sembiance/xu"),
	tiptoe = require("tiptoe"),
	C = require("../src/C.js"),
	fs = require("fs"),
	path = require("path"),
	util = require("util"),
	fileUtil = require("@sembiance/xutil").file,
	{Command} = require("commander"),
	dexvert = require("../src/dexvert.js");

const cmd = new Command().description("Processes <inputFilePath> converting or extracting files into <outputDirPath>").
	option("--verbose [level]", "Show additional info when processing. Levels 1 to 6 where 6 is most verbose").
	option("--brute [family...]", `If unable to identify <inputFilePath>, try converting anyways
		Pass a comma delimited list of families to brute force try
		Valid families: ${C.FAMILIES.join(" ")} or ${"all"}
		Successes will be stored in <outputDirPath>/<family>/<format>/ sub dirs
		WARNING: Multiple successes could use a lot of disk space`).
	option("--asFormat [family/formatid]", "Convert the format as a specific format. Don't identify the file").
	option("--keepGoing", "When brute forcing, don't stop at the first success. Try them all.").
	option("--alwaysBrute", "When brute forcing, always brute force, even if we have an exact id match.").
	option("--outputState", "If set, will output the state as JSON").
	option("--outputStateToFile [filePath]", "If set, will output the state as JSON to the given filePath").
	option("--brutePrograms", "If unable to identify <inputFilePath> just run every available program on it").
	option("--dontTransform", "If a file can't be converted, dexvert will try different transforms to convert it.").
	option("--useTmpOutputDir", "If set, dexvert won't clobber the output dir").
	option("--programFlag [program:flagName:flagValue...]", "If set, the given flagName and flagValue will be used for program. Possible flags include:");

fileUtil.globSync(path.join(__dirname, "..", "src", "program"), "**/*.js", {nodir : true}).forEach(programFilePath =>
{
	const prog = require(programFilePath);	// eslint-disable-line node/global-require
	Object.forEach((prog.meta.flags || {}), (k, v) => cmd.option(`    ${path.basename(programFilePath, ".js")}:${k}`, v));
});

const argv = cmd.arguments("<inputFilePath> <outputDirPath>").parse(process.argv);

if(argv.args.length<2)
{
	XU.log`Not enough args...`;
	argv.help();
}

const verbose = +(argv.verbose || 0);

tiptoe(
	function runProcess()
	{
		const processOptions = {verbose, programFlags : {}};
		["useTmpOutputDir", "brute", "asFormat", "keepGoing", "alwaysBrute", "brutePrograms", "dontTransform"].forEach(k =>
		{
			if(argv.hasOwnProperty(k))
				processOptions[k] = argv[k];
		});
		
		Array.force(argv.programFlag || []).forEach(flag =>
		{
			const flagProps = (flag.match(/(?<p>[^:]+):(?<k>[^:]+):(?<v>.+)/) || {groups : {}}).groups;
			if(!processOptions.programFlags[flagProps.p])
				processOptions.programFlags[flagProps.p] = {};
			processOptions.programFlags[flagProps.p][flagProps.k] = flagProps.v;
		});

		dexvert.process(argv.args[0], argv.args[1], processOptions, this);
	},
	function printResults(state)
	{
		if(argv.outputStateToFile)
			return fs.writeFile(argv.outputStateToFile, JSON.stringify(state), XU.UTF8, this);

		if(argv.outputState)
			console.log(JSON.stringify(state));
		else if(state.verbose>=2)
			console.log(util.inspect(state, {colors : true, depth : Infinity}));

		this();
	},
	XU.FINISH
);
