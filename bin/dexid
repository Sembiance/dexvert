#!/usr/bin/env node
"use strict";
const XU = require("@sembiance/xu"),
	cmdUtil = require("@sembiance/xutil").cmd,
	tiptoe = require("tiptoe"),
	fs = require("fs"),
	printUtil = require("@sembiance/xutil").print,
	dexvert = require("../src/dexvert.js");

const argv = cmdUtil.cmdInit({
	version : "1.0.0",
	desc    : "Identifies <inputFilePath>. Like an advanced 'file' command",
	opts    :
	{
		verbose  : {desc : "Show additional info when identifying. Levels 1 to 6 where 6 is most verbose", defaultValue : 0},
		json     : {desc : "Output JSON"},
		jsonFile : {desc : "If set, will output the result JSON to the given filePath", hasValue : true}
	},
	args :
	[
		{argid : "inputFilePath", desc : "One or more file paths to identify", required : true, multiple : true}
	]});

tiptoe(
	function performIdentification()
	{
		dexvert.identify(argv.inputFilePath, {verbose : argv.verbose || 0}, this);
	},
	function processIdentification(results)
	{
		if(argv.json)
		{
			console.log(JSON.stringify(results));
			this();
		}
		else if(argv.jsonFile)
		{
			fs.writeFile(argv.jsonFile, JSON.stringify(results), XU.UTF8, this);
		}
		else
		{
			console.log(printUtil.columnizeObjects(results, {
				colNames   : ["confidence", "from", "magic", "extensions", "extMatch", "untrustworthy"],
				colNameMap : {confidence : "%"},
				formatter(colName, val) { return (colName==="confidence" ? (val ? `${val}%` : "") : (colName==="extensions" ? (val || []).join(", ") : val || "")); }}));
			this();
		}
	},
	XU.FINISH
);
