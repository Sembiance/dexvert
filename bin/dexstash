#!/bin/bash

if [ "$#" -lt 2 ]; then
    echo "Usage: dexstash <family/format> <file> ..."
    exit
fi

formatid="$1"
shift

if [ -f "/mnt/compendium/DevLab/dexvert/src/format/""$formatid"".js" ]
then
	formatDir="/mnt/compendium/DevLab/dexvert/test/sample/""$formatid""/"
	mkdir -p "$formatDir"

	cp "$@" "$formatDir"

	echo "# of $formatid files: "`find "$formatDir" -type f | wc -l`
else
	echo "Unknown format: $formatid"
fi

