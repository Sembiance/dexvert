#!/usr/bin/env node
"use strict";
const XU = require("@sembiance/xu"),
	tiptoe = require("tiptoe"),
	C = require("../src/C.js"),
	fs = require("fs"),
	path = require("path"),
	util = require("util"),
	fileUtil = require("@sembiance/xutil").file,
	cmdUtil = require("@sembiance/xutil").cmd,
	dexvert = require("../src/dexvert.js");

const cmdData = {
	version : "1.0.0",
	desc    : "Processes <inputFilePath> converting or extracting files into <outputDirPath>",
	opts    :
	{
		verbose : {desc : "Show additional info when processing. Levels 1 to 6 where 6 is most verbose", defaultValue : 0},
		brute   : {desc : `If unable to identify <inputFilePath>, try converting anyways
			Pass a comma delimited list of families to brute force try
			Valid families: ${C.FAMILIES.join(" ")} or ${"all"}
			Successes will be stored in <outputDirPath>/<family>/<format>/ sub dirs
			WARNING: Multiple successes could use a lot of disk space`, hasValue : true, multiple : true},
		asFormat          : {desc : "Convert the format as [family/formatid]. Don't identify the file", hasValue : true},
		keepGoing         : {desc : "When brute forcing, don't stop at the first success. Try them all."},
		alwaysBrute       : {desc : "When brute forcing, always brute force, even if we have an exact id match."},
		outputState       : {desc : "If set, will output the state as JSON"},
		outputStateToFile : {desc : "If set, will output the state as JSON to the given filePath", hasValue : true},
		brutePrograms     : {desc : "If unable to identify <inputFilePath> just run every available program on it"},
		dontTransform     : {desc : "If a file can't be converted, dexvert will try different transforms (like trimming null bytes) to convert it."},
		useTmpOutputDir   : {desc : "If set, dexvert won't clobber the output dir"},
		programFlag       : {desc : "One or more [program:flagName:flagValue...] values. If set, the given flagName and flagValue will be used for program. Possible flags include:", hasValue : true, multiple : true}
	},
	args :
	[
		{argid : "inputFilePath", desc : "One or more file paths to convert", required : true},
		{argid : "outputDirPath", desc : "Output directory path", required : true}
	]};

fileUtil.globSync(path.join(__dirname, "..", "src", "program"), "**/*.js", {nodir : true}).forEach(programFilePath =>
{
	const prog = require(programFilePath);	// eslint-disable-line node/global-require
	Object.forEach((prog.meta.flags || {}), (k, v) => { cmdData.opts.programFlag.desc += `\n    ${path.basename(programFilePath, ".js")}:${k} => ${v}`; });
});

const argv = cmdUtil.cmdInit(cmdData);
const verbose = +(argv.verbose || 0);

tiptoe(
	function runProcess()
	{
		const processOptions = {verbose, programFlags : {}};
		["useTmpOutputDir", "brute", "asFormat", "keepGoing", "alwaysBrute", "brutePrograms", "dontTransform"].forEach(k =>
		{
			if(argv.hasOwnProperty(k))
				processOptions[k] = argv[k];
		});
		
		Array.force(argv.programFlag || []).forEach(flag =>
		{
			const flagProps = (flag.match(/(?<p>[^:]+):(?<k>[^:]+):(?<v>.+)/) || {groups : {}}).groups;
			if(!processOptions.programFlags[flagProps.p])
				processOptions.programFlags[flagProps.p] = {};
			processOptions.programFlags[flagProps.p][flagProps.k] = flagProps.v;
		});

		dexvert.process(argv.inputFilePath, argv.outputDirPath, processOptions, this);
	},
	function printResults(state)
	{
		if(argv.outputStateToFile)
			return fs.writeFile(argv.outputStateToFile, JSON.stringify(state), XU.UTF8, this);

		if(argv.outputState)
			console.log(JSON.stringify(state));
		else if(state.verbose>=2)
			console.log(util.inspect(state, {colors : true, depth : Infinity}));

		this();
	},
	XU.FINISH
);
