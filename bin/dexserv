#!/usr/bin/env node
"use strict";
const XU = require("@sembiance/xu"),
	tiptoe = require("tiptoe"),
	C = require("../lib/C.js"),
	runUtil = require("@sembiance/xutil").run,
	fs = require("fs"),
	path = require("path"),
	fileUtil = require("@sembiance/xutil").file,
	fastify = require("fastify")({logger : {level : "warn"}});

const WINE_RUN_ENV = {DISPLAY : ":0", WINEPREFIX : C.WINE_PREFIX_DIR_PATH};
const LOCKS = {};

let unoconvCP = null;
let shuttingDown = false;

function shutdown()
{
	if(shuttingDown)
		return;
		
	XU.log`Shutting down dexserv...`;
	shuttingDown = true;

	tiptoe(
		function killChildrenAndWine()
		{
			[unoconvCP].parallelForEach((cp, subcb) =>
			{
				if(cp && !cp.killed)
				{
					cp.on("exit", () => setImmediate(subcb));
					cp.kill();
				}
				else
				{
					setImmediate(subcb);
				}
			}, this.parallel());

			runUtil.run("wineserver", ["--kill"], {silent : true, env : WINE_RUN_ENV}, this.parallel());
		},
		XU.FINISH
	);
}

process.on("SIGTERM", () =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Terminate caught.`;
	shutdown();
});

process.on("SIGINT", () =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Interrupt caught.`;
	shutdown();
});

process.on("uncaughtException", err =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Uncaught exception.`;
	console.error(err);
	shutdown();
});

function startUnoconvServer()
{
	if(unoconvCP!==null)
		return;

	XU.log`Starting up unoconv server on port ${C.UNOCONV_PORT}`;

	unoconvCP = runUtil.run("unoconv", ["-p", C.UNOCONV_PORT, "-l"], {silent : true, detached : true});
	unoconvCP.on("exit", () =>
	{
		if(shuttingDown)
			return;

		XU.log`Unoconv server has exited, restarting...`;
		unoconvCP = null;
		startUnoconvServer();
	});
}

function startWine(cb)
{
	tiptoe(
		function removePreviousEnv()
		{
			XU.log`Preparing wine env prefix...`;

			fileUtil.unlink(C.WINE_PREFIX_DIR_PATH, this);
		},
		function createEnvDir()
		{
			fs.mkdir(C.WINE_PREFIX_DIR_PATH, {recursive : true}, this);
		},
		function extractEnv()
		{
			runUtil.run("tar", ["-xf", path.join("..", "wine", "env.tar"), "-C", C.WINE_PREFIX_DIR_PATH], runUtil.SILENT, this);
		},
		function startWineserver()
		{
			XU.log`Starting wineserver...`;
			runUtil.run("wineserver", ["--persistent"], {silent : true, detached : true, env : WINE_RUN_ENV});
			
			// Wait for wineserver to start fully. Maybe there is a better way to check this.
			setTimeout(() => this(), XU.SECOND*3);
		},
		function startWineboot()
		{
			XU.log`Starting wineboot...`;
			// Ok, so in theory wineboot runs and then exits. But wineboot is a maze of shell scripts and for some reason child_process.execFile() never returns when running wineboot (see sandbox/legacy/testWinebootProblem.js)
			// It likely has something to do with this: https://github.com/nodejs/node/issues/5637
			// Though maybe not, because I watched the returned process for any events and nothing ever triggers.
			// So we just run it detached and wait a bit before continuing. Gross and ugly, but I couldn't come up with another workaround
			runUtil.run("wineboot", ["--update"], {silent : true, detached : true, env : WINE_RUN_ENV});
			setTimeout(() => this(), XU.SECOND*10);
		},
		cb
	);
}

tiptoe(
	function preInit()
	{
		startWine(this);
	},
	function runServers()
	{
		startUnoconvServer();
		
		XU.log`Registering routes...`;

		fastify.get("/status", (request, reply) => reply.send({status : (unoconvCP ? C.DEXSERV_OK_RESPONSE : "error: unoconv server no longer running!")}));
		fastify.get("/lock", (request, reply) =>
		{
			if(LOCKS[request.query.lockid])
			{
				reply.send({status : "busy"});
			}
			else
			{
				LOCKS[request.query.lockid] = true;
				reply.send({status : "locked"});
			}
		});
		fastify.get("/unlock", (request, reply) =>
		{
			delete LOCKS[request.query.lockid];
			reply.send({status : "unlocked"});
		});

		fastify.ready(this);
	},
	function startServer()
	{
		console.log(fastify.printRoutes());
		fastify.listen({port : C.DEXSERV_PORT, host : C.DEXSERV_HOST}, this);
	},
	function finish(err)
	{
		if(err)
		{
			console.error(err);
			process.exit(1);
		}

		XU.log`Listening!`;
	}
);
