#!/usr/bin/env node
"use strict";

const XU = require("@sembiance/xu"),
	path = require("path"),
	tiptoe = require("tiptoe"),
	cueParser = require("cue-parser"),
	dexvert = require("../lib/dexvert.js"),
	argv = require("minimist")(process.argv.slice(2), {boolean : true}),
	fileUtil = require("@sembiance/xutil").file,
	httpUtil = require("@sembiance/xutil").http,
	C = require("../lib/C.js"),
	dexUtil = require("../lib/dexUtil.js"),
	fs = require("fs"),
	runUtil = require("@sembiance/xutil").run;

function usage(msg) { process.exit(XU.log`Usage: ${"uniso"} ${"<input.iso>"} ${"<outDirPath>"}\n${msg ? XU.c.fg.red + msg : ""}`); }

if(argv._.length!==2)
	return usage();

const inputFilePath = path.resolve(`${argv._[0]}`);
if(!fileUtil.existsSync(inputFilePath))
	return usage(`Input file ${inputFilePath} does not exist.`);

const OUT_DIR_PATH = path.resolve(`${argv._[1]}`);

const WIP_DIR_PATH = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined);
const MOUNT_DIR_PATH = path.join(WIP_DIR_PATH, "mountme");
const ISO_FILE_PATH = path.join(WIP_DIR_PATH, path.basename(inputFilePath));
const CUE_FILE_PATH = path.join(WIP_DIR_PATH, `${path.basename(inputFilePath, path.extname(inputFilePath))}.${!path.extname(inputFilePath).match(/[A-Z]/) ? "cue" : "CUE"}`);
const RUN_OPTIONS = {silent : true, cwd : WIP_DIR_PATH};

// First thing we do is look for any CUE files in the same directory as our ISO file that are dexvert identified as a cue sheet and are properly parsed by cue-parser and contains references to our ISO file
// If we don't a valid CUE file, we assume it's a single ISO file and we generate a fake CUE file so cdemu will work correctly
// If it's an HFS ISO, we have to use 'hfsutils' bin programs to manually copy everything out, since we want the resource forks too and 'mount' doesn't support that

function makeCueFile(cb)
{
	fs.writeFile(CUE_FILE_PATH, `FILE "${path.basename(inputFilePath)}" BINARY
  TRACK 01 MODE1/2048
    INDEX 01 00:00:00`, XU.UTF8, cb);
}

tiptoe(
	function findCUEFiles()
	{
		dexvert.identify(inputFilePath, this.parallel());
		fileUtil.glob(path.dirname(inputFilePath), "*.cue", {nocase : true}, this.parallel());
		fs.mkdir(MOUNT_DIR_PATH, {recursive : true}, this.parallel());
	},
	function identifyCUEFiles(isoIdentifications, cueFilePaths)
	{
		this.data.isoIdentifications = isoIdentifications;

		this.data.isCDISO =  isoIdentifications.filter(v => v.from==="dexvert").multiSort(v => v.confidence, true)[0].formatid==="iso";
		this.data.isRawDiskImage =  isoIdentifications.filter(v => v.from==="dexvert").multiSort(v => v.confidence, true)[0].formatid==="rawDiskImage";
		if(!this.data.isCDISO)
			return this.jump(1);

		if(!cueFilePaths || cueFilePaths.length===0)
			return makeCueFile(err => this.jump(1, err));
		
		this.data.cueFilePaths = cueFilePaths;
		this.data.cueFilePaths.parallelForEach((cueFilePath, subcb) => dexvert.identify(cueFilePath, {}, subcb), this);
	},
	function findMatchingCUEFile(cueFileIdentifications)
	{
		let matchingCue = null;
		(this.data.cueFilePaths || []).forEach((cueFilePath, i) =>
		{
			if(!cueFileIdentifications[i].some(cueFileIdentification => cueFileIdentification.magic==="Cue Sheet"))
				return;
			
			const cueData = cueParser.parse(cueFilePath);
			if(!cueData || !cueData.files || cueData.files.length===0)
				return;
			
			const matchingFile = cueData.files.find(file => path.basename(file.name.toLowerCase())===path.basename(inputFilePath.toLowerCase()));
			if(!matchingFile)
				return;

			matchingCue = {cueFilePath, data : matchingFile};
		});

		if(!matchingCue)
			makeCueFile(this);
		else
			fs.symlink(matchingCue.cueFilePath, CUE_FILE_PATH, this);
	},
	function symlinkISO()
	{
		fs.symlink(inputFilePath, ISO_FILE_PATH, this);
	},
	function checkIfVCD()
	{
		if(this.data.isRawDiskImage)
		{
			runUtil.run("/usr/bin/file", ["-L", ISO_FILE_PATH], this);
			return;
		}

		if(!this.data.isCDISO)
			return this();

		runUtil.run("vcd-info", ["-c", CUE_FILE_PATH, "--show-info=vers"], RUN_OPTIONS, this);
	},
	function getVirtualDeviceNum(isoInfo)
	{
		// Video CD's are special and need to be ripped with vcdxrip, otherwise we get input/output errors trying to copy the mpegav data
		if(isoInfo && isoInfo.split("\n").some(line => line.startsWith(" version: ")))
			return vcdRip(err => this.jump(-1, err));

		if(this.data.isRawDiskImage)
		{
			const startSector = (isoInfo.match(/startsector (?<startSector>\d+)/) || {groups : {}}).groups.startSector;
			if(startSector && (+startSector)>0)
			{
				runUtil.run("sudo", ["mount", "-o", `loop,offset=${(+startSector)*512}`, ISO_FILE_PATH, MOUNT_DIR_PATH], RUN_OPTIONS, err => this.jump(5, err));
				return;
			}
		}

		if(!this.data.isCDISO)
		{
			// Non CD images should just be mounted directly
			runUtil.run("sudo", ["mount", ISO_FILE_PATH, MOUNT_DIR_PATH], RUN_OPTIONS, err => this.jump(5, err));
			return;
		}

		// HFS CD's must be processed manually
		if(this.data.isoIdentifications.some(identification => ["ISO9660/HFS hybrid CD image", /^Apple Driver Map.*Apple_HFS/].some(matchAgainst => dexUtil.flexMatch(identification.magic, matchAgainst))))
			return extractHFSISO(err => this.jump(-1, err));

		httpUtil.get(`http://127.0.0.1:${C.DEXSERV_PORT}/getCDEmuDeviceNum`, this);
	},
	function unloadExistingDevice(getDeviceNumResponse)
	{
		this.data.deviceNum = JSON.parse(getDeviceNumResponse).deviceNum;
		runUtil.run("cdemu", ["unload", `${this.data.deviceNum}`], RUN_OPTIONS, this);
	},
	function loadIntoVirtualDevice()
	{
		runUtil.run("cdemu", ["load", `${this.data.deviceNum}`, CUE_FILE_PATH], RUN_OPTIONS, this);
	},
	function queryStatusAndDeviceMapping()
	{
		runUtil.run("cdemu", ["status"], RUN_OPTIONS, this.parallel());
		runUtil.run("cdemu", ["device-mapping"], RUN_OPTIONS, this.parallel());
	},
	function mountISO(statusRaw, deviceMappingRaw)
	{
		(statusRaw || "").trim().split("\n").forEach(statusLine =>
		{
			const statusInfo = (statusLine.trim().match(/(?<deviceNum>\d+)\s+(?<loaded>True|False)\s+(?<filename>.+)/) || {}).groups;
			if(statusInfo && +statusInfo.deviceNum===this.data.deviceNum && statusInfo.loaded!=="True")
				throw new Error(`Failed to load CUE file ${CUE_FILE_PATH} into deviceNum ${this.data.deviceNum} ${statusRaw}`);
		});
		
		let devPath = null;
		(deviceMappingRaw || "").trim().split("\n").forEach(deviceLine =>
		{
			const deviceInfo = (deviceLine.trim().match(/(?<deviceNum>\d+)\s+(?<devPath>\S+)\s+(?<genericPath>.+)/) || {}).groups;
			if(!deviceInfo || (+deviceInfo.deviceNum)!==this.data.deviceNum)
				return;

			devPath = deviceInfo.devPath.trim();
		});

		if(!devPath || devPath.length===0)
			throw new Error(`Failed to find matching device path for num ${this.data.deviceNum} ${deviceMappingRaw}`);

		this.data.devPath = devPath;

		//this.data.loopNum = dexUtil.allocateLoopDev(this.data.devPath);
		//runUtil.run("sudo", ["mount", `/dev/loop${this.data.loopNum}`, MOUNT_DIR_PATH], RUN_OPTIONS, this);
		// So doing it this way was causing weird problems. Some files on PCD1235.cue (photo_cd/images/img0098.pcd for example) would appear as empty zero sized files
		// Mounting directly seems to work fine. It's also safer in this case due to the way I'm emulating a virtual device with cdemu

		runUtil.run("sudo", ["mount", this.data.devPath, MOUNT_DIR_PATH], RUN_OPTIONS, this);
	},
	function extractAnyAudio()
	{
		runUtil.run("libcdio-paranoia", ["-w", "-d", this.data.devPath, "-B"], {silent : true, cwd : OUT_DIR_PATH}, this);
	},
	function copyFiles()
	{
		runUtil.run("sudo", ["cp", "-r", "*", `"${OUT_DIR_PATH}/"`], {...RUN_OPTIONS, shell : "/bin/bash", cwd : MOUNT_DIR_PATH}, this);
	},
	function fixPermissionsAndUnmount()
	{
		runUtil.run("sudo", ["umount", MOUNT_DIR_PATH], RUN_OPTIONS, this);
	},
	function removeVirtualDevice()
	{
		if(this.data.isCDISO)
			runUtil.run("cdemu", ["unload", `${this.data.deviceNum}`], RUN_OPTIONS, this);
		else
			this();
	},
	function cleanup()
	{
		fileUtil.unlink(WIP_DIR_PATH, this);
	},
	XU.FINISH
);

function vcdRip(cb)
{
	tiptoe(
		function runVCDXRip()
		{
			runUtil.run("vcdxrip", ["-c", CUE_FILE_PATH], {...RUN_OPTIONS, cwd : OUT_DIR_PATH}, this);
		},
		function stripCommentsFromXML()
		{
			// vcdxrip creates an XML file with a comment with the current command being executed which causes this file to change from run to run due to temp dir, etc.
			// Supposed to be able to pass "--no-command-comment" to vcdxrip to prevent this, but it does not work for me. So we use xmlstarlet to strip out comments
			runUtil.run("xmlstarlet", ["-q", "c14n", "--without-comments", "videocd.xml"], {...RUN_OPTIONS, cwd : OUT_DIR_PATH}, this);
		},
		function saveNewXMLFile(xmlRaw)
		{
			if(!xmlRaw || xmlRaw.length===0)
				return this();
			
			fs.writeFile(path.join(OUT_DIR_PATH, "videocd.xml"), `<?xml version="1.0"?>\n${xmlRaw}`, XU.UTF8, this);
		},
		cb
	);
}

const HCDNUM_BIN = path.join(__dirname, "hcdnum");
const HCOPYFILES_BIN = path.join(__dirname, "hcopyfiles");

function extractHFSISO(cb)
{
	const homeDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined);
	// All the hfsutils store their 'state' in a file written to home, so we create a temporary fake home to not clobber other extractions taking place
	const runOptions = {silent : true, env : {"HOME" : homeDirPath}};

	const recurseHFS = function recurseHFS(subPath, recursecb)
	{
		tiptoe(
			function mkdir()
			{
				fs.mkdir(path.join(OUT_DIR_PATH, subPath), {recursive : true}, this);
			},
			function copyOutFiles()
			{
				runUtil.run(HCOPYFILES_BIN, [path.join(OUT_DIR_PATH, subPath)], runOptions, this);
			},
			function getDirListing()
			{
				runUtil.run("hls", ["-alq"], runOptions, this);
			},
			function processDirListing(itemLines)
			{
				itemLines.trim().split("\n").filterEmpty().serialForEach((itemLine, subcb, lineNum) =>
				{
					const itemInfo = (itemLine.trim().match(/^(?<type>f|d)i?\s.+(?<year>\d{4})\s(?<filename>.+)$/) || {}).groups;
					if(!itemInfo)
					{
						console.error("ERROR, FIXME failed to parse itemLine: [%s]", itemLine);
						return setImmediate(subcb);
					}

					if(itemInfo.type==="f")
						return setImmediate(subcb);

					tiptoe(
						function changeDir()
						{
							runUtil.run(HCDNUM_BIN, [`${(lineNum+1)}`], runOptions, this);
						},
						function recurseIntoDir()
						{
							recurseHFS(path.join(subPath, itemInfo.filename), this);
						},
						function recurseBackOut()
						{
							runUtil.run("hcd", ["::"], runOptions, this);
						},
						subcb
					);
				}, this);
			},
			recursecb
		);
	};

	tiptoe(
		function prepare()
		{
			fs.mkdir(homeDirPath, {recursive : true}, this);
		},
		function mountImage()
		{
			runUtil.run("hmount", [ISO_FILE_PATH], runOptions, this);
		},
		function startRecursion()
		{
			recurseHFS("", this);
		},
		function unmountImage()
		{
			runUtil.run("humount", [ISO_FILE_PATH], runOptions, this);
		},
		function findExtractedFiles()
		{
			fileUtil.glob(OUT_DIR_PATH, "**", {nodir : true}, this);
		},
		function extractResourceForks(extractedFilePaths)
		{
			extractedFilePaths.parallelForEach((extractedFilePath, subcb) =>
			{
				const tmpUnpackDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined, "");
				const tmpSafeNameFilePath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined, "");

				tiptoe(
					function prepareTmp()
					{
						fs.mkdir(tmpUnpackDirPath, {recursive : true}, this.parallel());
						fs.copyFile(extractedFilePath, tmpSafeNameFilePath, this.parallel());
					},
					function unpackIntoTmpDir()
					{
						runUtil.run("unar", ["-f", "-D", "-o", tmpUnpackDirPath, tmpSafeNameFilePath], {silent : false}, this);
					},
					function findUnpackedFiles()
					{
						fileUtil.glob(tmpUnpackDirPath, "*", {nodir : true}, this);
					},
					function moveFiles(unpackedFilePaths)
					{
						if(unpackedFilePaths.length===0)
							return this();

						unpackedFilePaths.parallelForEach((unpackedFilePath, unpackcb) => fileUtil.move(unpackedFilePath, path.join(path.dirname(extractedFilePath), path.basename(unpackedFilePath)), unpackcb), this);
					},
					function cleanupUnpack()
					{
						fileUtil.unlink(tmpUnpackDirPath, this.parallel());
						fileUtil.unlink(tmpSafeNameFilePath, this.parallel());
					},
					subcb
				);
			}, this);
		},
		function cleanup()
		{
			fileUtil.unlink(homeDirPath, this);
		},
		cb
	);
}
