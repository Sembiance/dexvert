#!/usr/bin/env node
"use strict";

const XU = require("@sembiance/xu"),
	path = require("path"),
	tiptoe = require("tiptoe"),
	cueParser = require("cue-parser"),
	dexvert = require(path.join(__dirname, "..", "lib", "dexvert.js")),
	C = require(path.join(__dirname, "..", "lib", "C.js")),
	argv = require("minimist")(process.argv.slice(2), {boolean : true}),
	fileUtil = require("@sembiance/xutil").file,
	dexUtil = require(path.join(__dirname, "..", "lib", "dexUtil.js")),
	fs = require("fs"),
	runUtil = require("@sembiance/xutil").run;

function usage(msg) { process.exit(XU.log`Usage: ${"uniso"} ${"<input.iso>"} ${"<outDirPath>"}\n${msg ? XU.c.fg.red + msg : ""}`); }

if(argv._.length!==2)
	return usage();

const inputFilePath = "" + argv._[0];
if(!fileUtil.existsSync(inputFilePath))
	return usage(`Input file ${inputFilePath} does not exist.`);

const outDirPath = "" + argv._[1];

const tmpDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined);
const mountDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined);

// First thing we do is look for any CUE files in the same directory as our ISO file
// If we find any and they are identified as a cue sheet and properly parsed by cue-parser, then IF the cue references our ISO file, then we use bchunk to extract any audio tracks and data tracks as seperate ISO files
// Then we proceed with extractISOFile() which now is being passed a valid ISO.
// We check in there if it's an HFS ISO, because if so we need to use 'hfsutils' bin programs to manually copy everything out, since we want the resource forks too and 'mount' doesn't support that

tiptoe(
	function findCUEFiles()
	{
		fileUtil.glob(path.dirname(inputFilePath), "*.cue", {nocase : true}, this.parallel());
		fs.mkdir(outDirPath, {recursive : true}, this.parallel());
		fs.mkdir(tmpDirPath, {recursive : true}, this.parallel());
		fs.mkdir(mountDirPath, {recursive : true}, this.parallel());
	},
	function verifyCUEFiles(cueFilePaths)
	{
		if(!cueFilePaths || cueFilePaths.length===0)
			return this.jump(4, undefined, inputFilePath);
		
		this.data.cueFilePaths = cueFilePaths;
		this.data.cueFilePaths.parallelForEach(dexvert.identify, this);
	},
	function processCUEFiles(cueFileIdentifications)
	{
		let matchingCue = null;
		this.data.cueFilePaths.forEach((cueFilePath, i) =>
		{
			if(!cueFileIdentifications[i].some(cueFileIdentification => cueFileIdentification.magic==="Cue Sheet"))
				return;
			
			const cueData = cueParser.parse(cueFilePath);
			if(!cueData || !cueData.files || cueData.files.length===0)
				return;
			
			const matchingFile = cueData.files.find(file => path.basename(file.name)===path.basename(inputFilePath));
			if(!matchingFile)
				return;

			matchingCue = {cueFilePath, data : matchingFile};
		});

		if(!matchingCue || !matchingCue.data.tracks || matchingCue.data.tracks.length===1)
			return this.jump(3, undefined, inputFilePath);
		
		this.data.matchingCue = matchingCue;

		runUtil.run("bchunk", ["-w", path.relative(outDirPath, inputFilePath), path.relative(outDirPath, matchingCue.cueFilePath), path.basename(inputFilePath, path.extname(inputFilePath)) + "_track"], {verbose : true, cwd : outDirPath}, this);
	},
	function findResultingISOs()
	{
		fileUtil.glob(outDirPath, "*.iso", this);
	},
	function moveResultingISO(generatedISOFilePaths)
	{
		if(generatedISOFilePaths.length===0)
			return this(undefined, inputFilePath);
		
		this.data.tmpISOPath = path.join(tmpDirPath, path.basename(generatedISOFilePaths[0]));
		fileUtil.move(generatedISOFilePaths[0], this.data.tmpISOPath, err => this(err, this.data.tmpISOPath));
	},
	function extractISO(isoFilePath)
	{
		extractISOFile(isoFilePath, this);
	},
	function cleanup()
	{
		fileUtil.unlink(tmpDirPath, this.parallel());
		fileUtil.unlink(mountDirPath, this.parallel());
	},
	XU.FINISH
);

function extractISOFile(isoFilePath, cb)
{
	tiptoe(
		function identifyISOFile()
		{
			dexvert.identify(isoFilePath, this);
		},
		function mountISO(identifications)
		{
			if(identifications.some(identification => ["identifications ISO9660/HFS hybrid CD image", /^Apple Driver Map.*Apple_HFS/].some(matchAgainst => C.flexMatch(identification.magic, matchAgainst))))
				return extractHFSISO(isoFilePath, this.finish);

			// Just a regular ISO, mount it and copy the files over
			this.data.loopNum = dexUtil.allocateLoopDev(isoFilePath);
			
			runUtil.run("sudo", ["mount", "/dev/loop" + this.data.loopNum, mountDirPath], {liveOutput : true}, this);
		},
		function copyFiles()
		{
			runUtil.run("cp", ["-r", "*", `"${path.resolve(outDirPath)}/"`], {liveOutput : true, shell : "/bin/bash", cwd : mountDirPath}, this);
		},
		function fixPermissionsAndUnmount()
		{
			runUtil.run("sudo", ["umount", mountDirPath], {liveOutput : true}, this);
			dexUtil.freeLoopDev(this.data.loopNum);
		},
		cb
	);
}

function extractHFSISO(isoFilePath, cb)
{
	const homeDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined);
	const runOptions = {silent : true, env : {"HOME" : homeDirPath}};

	const recurseHFS = function recurseHFS(subPath, recursecb)
	{
		tiptoe(
			function mkdir()
			{
				fs.mkdir(path.join(outDirPath, subPath), {recursive : true}, this);
			},
			function copyOutFiles()
			{
				runUtil.run("hcopyfiles", [path.join(outDirPath, subPath)], runOptions, this);
			},
			function getDirListing()
			{
				runUtil.run("hls", ["-alq"], runOptions, this);
			},
			function processDirListing(itemLines)
			{
				itemLines.trim().split("\n").filterEmpty().serialForEach((itemLine, subcb, lineNum) =>
				{
					const itemInfo = (itemLine.trim().match(/^(?<type>f|d)i?\s.+(?<year>\d{4})\s(?<filename>.+)$/) || {}).groups;
					if(!itemInfo)
					{
						console.error("ERROR, FIXME failed to parse itemLine: [%s]", itemLine);
						return setImmediate(subcb);
					}

					if(itemInfo.type==="f")
						return setImmediate(subcb);

					tiptoe(
						function changeDir()
						{
							runUtil.run("hcdnum", [""+(lineNum+1)], runOptions, this);
						},
						function recurseIntoDir()
						{
							recurseHFS(path.join(subPath, itemInfo.filename), this);
						},
						function recurseBackOut()
						{
							runUtil.run("hcd", ["::"], runOptions, this);
						},
						subcb
					);
				}, this);
			},
			recursecb
		);
	};

	tiptoe(
		function prepare()
		{
			fs.mkdir(homeDirPath, {recursive : true}, this);
		},
		function mountImage()
		{
			runUtil.run("hmount", [isoFilePath], runOptions, this);
		},
		function startRecursion()
		{
			recurseHFS("", this);
		},
		function unmountImage()
		{
			runUtil.run("humount", [isoFilePath], runOptions, this);
		},
		function findExtractedFiles()
		{
			fileUtil.glob(outDirPath, "**", {nodir : true}, this);
		},
		function extractResourceForks(extractedFilePaths)
		{
			extractedFilePaths.parallelForEach((extractedFilePath, subcb) =>
			{
				const tmpUnpackDirPath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined, "");
				const tmpSafeNameFilePath = fileUtil.generateTempFilePath(argv.tmpDirPath || undefined, "");

				tiptoe(
					function prepareTmp()
					{
						fs.mkdir(tmpUnpackDirPath, {recursive : true}, this.parallel());
						fs.copyFile(extractedFilePath, tmpSafeNameFilePath, this.parallel());
					},
					function unpackIntoTmpDir()
					{
						runUtil.run("unar", ["-f", "-D", "-o", tmpUnpackDirPath, tmpSafeNameFilePath], {silent : false}, this);
					},
					function findUnpackedFiles()
					{
						fileUtil.glob(tmpUnpackDirPath, "*", {nodir : true}, this);
					},
					function moveFiles(unpackedFilePaths)
					{
						if(unpackedFilePaths.length===0)
							return this();

						unpackedFilePaths.parallelForEach((unpackedFilePath, unpackcb) => fileUtil.move(unpackedFilePath, path.join(path.dirname(extractedFilePath), path.basename(unpackedFilePath)), unpackcb), this);
					},
					function cleanupUnpack()
					{
						fileUtil.unlink(tmpUnpackDirPath, this.parallel());
						fileUtil.unlink(tmpSafeNameFilePath, this.parallel());
					},
					subcb
				);
			}, this);
		},
		function cleanup()
		{
			fileUtil.unlink(homeDirPath, this);
		},
		cb
	);
}
