#!/usr/bin/env node
"use strict";

const XU = require("@sembiance/xu"),
	path = require("path"),
	tiptoe = require("tiptoe"),
	{Command} = require("commander"),
	fileUtil = require("@sembiance/xutil").file,
	fs = require("fs"),
	runUtil = require("@sembiance/xutil").run;

const argv = new Command().description("Processes <input.iso> as an ISO and extracting into <outputDirPath>\n[subType] is optional and currently allows: hfs").
	option("--offset [offset]", "If set, mount at the given offset").
	arguments("<input.iso> <outputDirPath> [subType]").
	parse(process.argv);

if(argv.args.length<2)
	argv.help();

const inputFilePath = path.resolve(argv.args[0]);
if(!fileUtil.existsSync(inputFilePath))
	return process.exit(console.error(`Input file ${inputFilePath} does not exist.`));

const OUT_DIR_PATH = path.resolve(argv.args[1]);

const SUB_TYPE = argv.args[2];

const WIP_DIR_PATH = fileUtil.generateTempFilePath(undefined, "-uniso");
const MOUNT_DIR_PATH = path.join(WIP_DIR_PATH, "m");
const RUN_OPTIONS = {silent : true};

tiptoe(
	function createMountDir()
	{
		fs.mkdir(MOUNT_DIR_PATH, {recursive : true}, this);
	},
	function performExtraction()
	{
		if(SUB_TYPE==="hfs")
			extractHFSISO(this);
		else
			extractNormalISO(this);
	},
	function cleanup()
	{
		fileUtil.unlink(WIP_DIR_PATH, this);
	},
	XU.FINISH
);

function extractNormalISO(cb)
{
	tiptoe(
		function mountISO()
		{
			const mountArgs = [];
			if(argv.offset)
				mountArgs.push("-o", `loop,offset=${argv.offset}`);

			runUtil.run("sudo", ["mount", ...mountArgs, inputFilePath, MOUNT_DIR_PATH], RUN_OPTIONS, this);
		},
		function copyFiles()
		{
			// We sudo out to cp because mount requires root AND cp does a good job at handling bad filenames
			runUtil.run("sudo", ["cp", "--preserve=timestamps", "-r", "*", `"${OUT_DIR_PATH}/"`], {...RUN_OPTIONS, shell : "/bin/bash", cwd : MOUNT_DIR_PATH}, this);
		},
		function unmountISO()
		{
			runUtil.run("sudo", ["umount", MOUNT_DIR_PATH], RUN_OPTIONS, this);
		},
		cb
	);
}

function extractHFSISO(cb)
{
	const HCDNUM_BIN = path.join(__dirname, "hcdnum");
	const HCOPYFILES_BIN = path.join(__dirname, "hcopyfiles");
	// All the hfsutils store their 'state' in a file written to home, so we create a temporary fake home to not clobber other extractions taking place
	const HLS_RUN_OPTIONS = {silent : true, env : {"HOME" : MOUNT_DIR_PATH}};

	const recurseHFS = function recurseHFS(subPath, recursecb)
	{
		tiptoe(
			function mkdir()
			{
				fs.mkdir(path.join(OUT_DIR_PATH, subPath), {recursive : true}, this);
			},
			function copyOutFiles()
			{
				runUtil.run(HCOPYFILES_BIN, [path.join(OUT_DIR_PATH, subPath)], HLS_RUN_OPTIONS, this);
			},
			function getDirListing()
			{
				runUtil.run("hls", ["-alq"], HLS_RUN_OPTIONS, this);
			},
			function processDirListing(itemLines)
			{
				itemLines.trim().split("\n").filterEmpty().serialForEach((itemLine, subcb, lineNum) =>
				{
					const itemInfo = (itemLine.trim().match(/^(?<type>f|d)i?\s.+(?<year>\d{4})\s(?<filename>.+)$/) || {}).groups;
					if(!itemInfo)
					{
						console.error("ERROR, FIXME failed to parse itemLine: [%s]", itemLine);
						return setImmediate(subcb);
					}

					if(itemInfo.type==="f")
						return setImmediate(subcb);

					tiptoe(
						function changeDir()
						{
							runUtil.run(HCDNUM_BIN, [`${(lineNum+1)}`], HLS_RUN_OPTIONS, this);
						},
						function recurseIntoDir()
						{
							recurseHFS(path.join(subPath, itemInfo.filename), this);
						},
						function recurseBackOut()
						{
							runUtil.run("hcd", ["::"], HLS_RUN_OPTIONS, this);
						},
						subcb
					);
				}, this);
			},
			recursecb
		);
	};

	tiptoe(
		function mountImage()
		{
			runUtil.run("hmount", [inputFilePath], HLS_RUN_OPTIONS, this);
		},
		function startRecursion()
		{
			recurseHFS("", this);
		},
		function unmountImage()
		{
			runUtil.run("humount", [inputFilePath], HLS_RUN_OPTIONS, this);
		},
		function findExtractedFiles()
		{
			fileUtil.glob(OUT_DIR_PATH, "**", {nodir : true}, this);
		},
		cb
	);
}
