#!/usr/bin/env node
"use strict";
const XU = require("@sembiance/xu"),
	path = require("path"),
	argv = require("minimist")(process.argv.slice(2), {boolean : true}),
	tiptoe = require("tiptoe"),
	C = require(path.join(__dirname, "..", "lib", "C.js")),
	runUtil = require("@sembiance/xutil").run,
	fileUtil = require("@sembiance/xutil").file,
	fastify = require("fastify")({logger : true});

const VHBA_CTL_DEV_PATH = "/dev/vhba_ctl";

function usage()
{
	XU.log`${XU.cf.fg.cyan("Usage:")} dexserv [options]

Starts a server to assist dexvert. Required for 'unoconv' doc conversion and ISO extraction.

${XU.cf.fg.cyan("Options:")}
  ${XU.cf.fg.yellow("--help")}
    Display help/usage`;
	process.exit(0);
}

if(argv.help)
	usage();

let cdEmuDeviceNum = 0;
let unoconvCP = null;
let cdemuCP = null;
let shuttingDown = false;

function shutdown()
{
	XU.log`Shutting down dexserv...`;
	shuttingDown = true;

	[unoconvCP, cdemuCP].parallelForEach((cp, subcb) =>
	{
		if(cp && !cp.killed)
		{
			cp.on("exit", () => setImmediate(subcb));
			cp.kill();
		}
		else
		{
			setImmediate(subcb);
		}
	}, XU.FINISH);
}

process.on("SIGTERM", () =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Terminate caught.`;
	shutdown();
});

process.on("SIGINT", () =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Interrupt caught.`;
	shutdown();
});

process.on("uncaughtException", err =>
{
	XU.log`${XU.c.blink + XU.cf.fg.red("***")} Uncaught exception.`;
	console.error(err);
	shutdown();
});

function startUnoconvServer()
{
	if(unoconvCP!==null)
		return;

	XU.log`Starting up unoconv server on port ${C.UNOCONV_PORT}`;

	unoconvCP = runUtil.run("unoconv", ["-p", C.UNOCONV_PORT, "-l"], {silent : true, detached : true});
	unoconvCP.on("exit", () =>
	{
		if(shuttingDown)
			return;

		XU.log`Unoconv server has exited, restarting...`;
		unoconvCP = null;
		startUnoconvServer();
	});
}

tiptoe(
	function verifyVHBALoaded()
	{
		fileUtil.exists(VHBA_CTL_DEV_PATH, this);
	},
	function runServers(vhbaCtlExists)
	{
		if(!vhbaCtlExists)
		{
			XU.log`Failed to find ${VHBA_CTL_DEV_PATH}. Might need to do \`modprobe vhba\``;
			process.exit(1);
		}
		console.log(vhbaCtlExists);

		startUnoconvServer();
		
		cdemuCP = runUtil.run("cdemu-daemon", [`--ctl-device=${VHBA_CTL_DEV_PATH}`, "--bus=session", "--num-devices=64", `--logfile=${path.join(__dirname, "..", "log", "cdemu-daemon.log")}`], {silent : true, detached : true});

		XU.log`Registering routes...`;

		fastify.get("/status", (request, reply) => reply.send({status : (unoconvCP ? C.DEXSERV_OK_RESPONSE : "error: unoconv server no longer running!")}));
		fastify.get("/getCDEmuDeviceNum", (request, reply) => reply.send({deviceNum : (cdEmuDeviceNum++)%64}));

		fastify.ready(this);
	},
	function startServer()
	{
		console.log(fastify.printRoutes());
		fastify.listen({port : C.DEXSERV_PORT, host : C.DEXSERV_HOST}, this);
	},
	function finish(err)
	{
		if(err)
		{
			console.error(err);
			process.exit(1);
		}
	}
);
