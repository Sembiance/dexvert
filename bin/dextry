#!/bin/bash

command rm -rf ~/tmp/out
mkdir -p ~/tmp/out

touch ~/tmp/out/deleteme

verboseLevel="4"
if [ "$1" == "--verbose" ]; then
	verboseLevel="5"
	shift
fi

if [ "$1" == "--allowTransform" ]; then
	allowTransform="yes"
	shift
fi

for filename in "$@"
do
	if [ "$allowTransform" == "yes" ]; then
		dexvert --verbose="$verboseLevel" "$filename" ~/tmp/out/ &
	else
		dexvert --dontTransform  --verbose="$verboseLevel" "$filename" ~/tmp/out/ &
	fi
done

wait

rm -f ~/tmp/out/deleteme
